---
import Post from "@/components/astro/Post.astro";
import { extractTags } from "@/lib/collection";

// posts: loadPosts()로 매핑된 { url, frontmatter } 배열
const { posts } = Astro.props;
const tags = extractTags(posts);
const PAGE_SIZE = 10;
---

<input
  id="search"
  type="search"
  placeholder="제목 · 태그 검색"
  autocomplete="off"
  class="w-full mb-4 px-4 py-2 rounded-lg border bg-transparent text-[rgb(var(--foreground))] placeholder:text-gray-500 focus:outline-none"
/>

<div id="tag-filter" class="mb-6 flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <button type="button" class="tag-chip" data-tag={String(tag).toLowerCase()}>
        {tag}
      </button>
    ))
  }
</div>

<ul id="post-list">
  {
    posts.map((post: any) => (
      <li
        class="post-item"
        data-title={(post.frontmatter.title || "").toLowerCase()}
        data-tags={(post.frontmatter.tags || "").toLowerCase()}
      >
        <Post
          url={post.url}
          title={post.frontmatter.title}
          pubDate={post.frontmatter.pubDate}
          description={post.frontmatter.description}
        />
      </li>
    ))
  }
</ul>

<p id="empty" class="hidden text-gray-500 dark:text-gray-400 mt-6">검색 결과가 없습니다.</p>

<nav id="pagination" class="flex flex-wrap gap-2 justify-center mt-8" aria-label="pagination"></nav>

<script is:inline define:vars={{ pageSize: PAGE_SIZE }}>
  const list = document.getElementById("post-list");
  const items = Array.from(list.querySelectorAll(".post-item"));
  const search = document.getElementById("search");
  const chips = Array.from(document.querySelectorAll(".tag-chip"));
  const pagination = document.getElementById("pagination");
  const empty = document.getElementById("empty");

  let query = "";
  const selectedTags = new Set();
  let page = 1;

  function itemTags(el) {
    return (el.dataset.tags || "")
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
  }

  function matches(el) {
    const okText =
      !query || (el.dataset.title || "").includes(query) || (el.dataset.tags || "").includes(query);
    if (!okText) return false;
    if (selectedTags.size === 0) return true;
    // 선택한 태그 중 하나라도 포함하면 노출 (OR)
    const tagsArr = itemTags(el);
    return [...selectedTags].some((t) => tagsArr.includes(t));
  }

  function makeButton(label, targetPage, { disabled = false, active = false } = {}) {
    const b = document.createElement("button");
    b.type = "button";
    b.textContent = label;
    b.disabled = disabled;
    b.className =
      "px-3 py-1 rounded border" +
      (active ? " bg-[rgb(var(--foreground))] text-[rgb(var(--background))]" : "") +
      (disabled ? " opacity-40 cursor-not-allowed" : " cursor-pointer");
    if (!disabled && !active) {
      b.addEventListener("click", () => {
        page = targetPage;
        render();
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }
    return b;
  }

  function render() {
    const filtered = items.filter(matches);
    const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
    if (page > totalPages) page = totalPages;

    const start = (page - 1) * pageSize;
    const end = start + pageSize;
    const visible = filtered.slice(start, end);

    items.forEach((el) => (el.style.display = "none"));
    visible.forEach((el) => (el.style.display = ""));

    empty.classList.toggle("hidden", filtered.length !== 0);

    pagination.innerHTML = "";
    if (totalPages > 1) {
      pagination.appendChild(makeButton("‹", page - 1, { disabled: page === 1 }));
      for (let i = 1; i <= totalPages; i++) {
        pagination.appendChild(makeButton(String(i), i, { active: i === page }));
      }
      pagination.appendChild(makeButton("›", page + 1, { disabled: page === totalPages }));
    }
  }

  search.addEventListener("input", (e) => {
    query = e.target.value.trim().toLowerCase();
    page = 1;
    render();
  });

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      const t = chip.dataset.tag;
      if (selectedTags.has(t)) {
        selectedTags.delete(t);
        chip.classList.remove("active");
      } else {
        selectedTags.add(t);
        chip.classList.add("active");
      }
      page = 1;
      render();
    });
  });

  render();
</script>

<style>
  .tag-chip {
    display: inline-block;
    border: 1px solid rgb(var(--foreground));
    border-radius: 2.5rem;
    padding: 0.1rem 1rem;
    line-height: 2rem;
    cursor: pointer;
    color: rgb(var(--foreground));
    background-color: transparent;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .tag-chip:hover {
    background-color: rgba(var(--foreground), 0.1);
  }

  .tag-chip.active {
    background-color: rgb(var(--foreground));
    color: rgb(var(--background));
  }
</style>
