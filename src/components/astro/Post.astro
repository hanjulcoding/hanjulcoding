---
import dayjs from 'dayjs';
const { title, url, pubDate } = Astro.props;
---

<a href={url} class="group flex items-baseline justify-between gap-4 border-b border-border py-3">
  <span class="min-w-0 truncate text-slate-600 dark:text-slate-200 group-hover:underline">{title}</span>
  {pubDate && (
    <time class="shrink-0 text-sm text-gray-500 dark:text-gray-400">{dayjs(pubDate).format('YYYY-MM-DD')}</time>
  )}
</a>
