---
import { format } from 'date-fns';
const { title, url, pubDate, description } = Astro.props;
---

<a href={url} class="group block border-b border-border py-3">
  <span class="flex items-baseline justify-between gap-4">
    <span class="min-w-0 truncate text-slate-600 dark:text-slate-200 group-hover:underline">{title}</span>
    {pubDate && (
      <time class="shrink-0 text-sm text-gray-500 dark:text-gray-400">{format(new Date(pubDate), 'yyyy-MM-dd')}</time>
    )}
  </span>
  {description && (
    <span class="mt-1 block text-sm text-gray-500 dark:text-gray-400">{description}</span>
  )}
</a>
