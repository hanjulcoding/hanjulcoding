---
import "@/style/page.scss";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Post from "@/components/astro/Post.astro";
import { pubDateSort } from "@/lib/utils";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  // content collection에서 글 가져오기 (astro-editor 연동)
  const postsArray = (await getCollection("news")).map((post) => ({
    ...post,
    url: `/news/${post.id}`,
    frontmatter: post.data,
  }));

  // Step 3: 태그 추출 및 정렬
  const uniqueTags = [
    ...new Set(
      postsArray
        .sort(pubDateSort as (a: unknown, b: unknown) => number)
        .map((post: any) =>
          post.frontmatter.tags?.split(",").map((tag: string) => tag.trim()) || []
        )
        .flat()
    ),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = postsArray.filter((post: any) => {
      const tagList = post.frontmatter.tags
        ?.split(",")
        .map((item: string) => item.trim()) || [];

        return tagList.includes(tag);
    }
    );
    return {
      params: { tag: tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag }: { tag: string } = Astro.params;
const { posts }: { posts: any } = Astro.props;
---

<BaseLayout title={`한줄코딩 - News:${tag}`}>
  <h1 class="mb-8">
    <a href={`/news`}><span class="tag">{tag}</span></a> 태그 관련 글
  </h1>
  <div>
    {posts.map((post: any) => (
      <Post url={post.url} title={post.frontmatter.title} pubDate={post.frontmatter.pubDate} />
    ))}
  </div>
</BaseLayout>
