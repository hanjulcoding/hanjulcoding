---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title={"한줄코딩 - About"}>
  <main
    class="min-h-[60vh] max-w-[calc(100%-2rem)] flex flex-col justify-center items-center mx-auto text-[rgb(var(--foreground))] text-lg leading-relaxed m-4 sm:m-4"
  >
    <div
      class="text-center text-gray-800 bg-gray-100 dark:bg-gray-800 dark:text-white shadow-2xl rounded-2xl p-12 w-full max-w-2xl"
    >
      <p class="text-xl text-gray-900 dark:text-white mb-4">한줄코딩</p>
      <p class="text-lg text-gray-900 dark:text-white">
        개발과 관련된 정보를 한 줄씩 기록하는 공간입니다.
      </p>
      <a
        href="https://github.com/6lueparr0t"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-8 px-5 py-2 rounded-lg border border-gray-800 dark:border-white text-gray-900 dark:text-white hover:bg-gray-900 hover:text-white dark:hover:bg-white dark:hover:text-gray-900 transition-colors"
      >
        개발자 GitHub 바로가기 →
      </a>
    </div>
  </main>
</BaseLayout>
