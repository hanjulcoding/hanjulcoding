---
import PostList from "@/components/astro/PostList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/style/page.scss";

// tool 하나 = 페이지 하나. 여기에 항목만 추가하면 목록/검색/태그에 노출됨.
const tools = [
  {
    url: "/tools/prompt-template",
    frontmatter: {
      title: "프롬프트 템플릿",
      description: "AI 프롬프트 생성 및 관리 도구",
      tags: "prompt, template, ai",
    },
  },
  {
    url: "/tools/md-to-plain-text",
    frontmatter: {
      title: "마크다운 제거기",
      description: "마크다운 문법을 일반 텍스트로 바꿔줌",
      tags: "markdown, text, ai",
    },
  },
  {
    url: "/tools/memo-share",
    frontmatter: {
      title: "메모 공유",
      description: "서버 없이 URL로 메모 내용을 공유",
      tags: "memo, share, url",
    },
  },
];
---

<BaseLayout title="한줄코딩 - Tools">
  <PostList posts={tools} />
</BaseLayout>
